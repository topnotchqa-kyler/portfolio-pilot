# Required for the Kyra chatbot (Anthropic Claude)
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here

# Required for the test coverage analyzer and image generation (Genkit + Google Gemini)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Your deployed site URL — used for SEO canonical URLs, Open Graph, and sitemap
# Set this in Vercel: Settings → Environment Variables
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
