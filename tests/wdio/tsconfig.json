{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["@wdio/globals/types", "@wdio/cucumber-framework"]
  },
  "include": ["./step-definitions/**/*.ts", "./page-objects/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
