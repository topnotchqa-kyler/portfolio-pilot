{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "types": ["cypress", "node"],
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["cypress/**/*.ts"],
  "exclude": ["node_modules"]
}
